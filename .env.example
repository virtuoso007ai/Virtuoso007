# @BotFather
TELEGRAM_BOT_TOKEN=

# Sadece bu Telegram kullanıcı/sohbet ID'leri (virgülle). Boş = tüm sohbetler (önerilmez).
ALLOWED_CHAT_IDS=

# ACP (varsayılan claw-api)
# ACP_API_URL=https://claw-api.virtuals.io
# ACP_BUILDER_CODE=

# Degen Claw web API (açık pozlar /positions) — genelde değiştirme
# DGCLAW_APP_URL=https://dgclaw-app-production.up.railway.app

# Trade aç/kapa sonrası forum (SIGNALS) — agent başına forumApiKey yoksa global dgc_ anahtar:
# DGCLAW_API_KEY=dgc_...

# Degen leaderboard (/leaderboard) — Virtuals API
# DEGEN_LEADERBOARD_SEASON_ID=2
# DEGEN_LEADERBOARD_API=https://degen.virtuals.io/api/leaderboard

# Açık limit listesi + /cancel taraması — mainnet (varsayılan) veya testnet
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# HYPERLIQUID_INFO_URL=https://api.hyperliquid-testnet.xyz/info

# ---------- AGENTS_JSON (HL v2 + bot) ----------
# Telegram bot ile aynı dizi: Railway / Vercel / .env dosyasına TEK SATIR olarak yapıştır.
# Tırnak ile sarmalama; değer doğrudan [ ile başlayan JSON olmalı.
#
# Hazırlık:
#   1) agents.v2.template.json kopyala → agents.local.json, placeholder'ları doldur.
#   2) Tek satır:  npm run agents:paste-file  →  AGENTS_JSON.paste.txt (gitignore) içeriğini kopyala
#
# Her agent için zorunlu:
#   alias            — küçük harf; komutlarda /open raichu gibi
#   apiKey           — (opsiyonel) Virtuals ACP lite key — sadece /acp/me ile cüzdan; HL v2 işlem için şart değil
#   walletAddress    — master cüzdan (Privy); HL v2 signing için zorunlu
#   hlApiWalletKey   — (opsiyonel) JSON icinde tutma; tercih: secrets/hl-api-wallets.env + npm run hl:sync-api-keys
#   (Alternatif) Railway secret: HL_API_WALLET_KEY_<ALIAS> — örn. HL_API_WALLET_KEY_TAXERCLAW
#   Yerel tek dosya: secrets/hl-api-wallets.env (gitignore) — ornek: secrets/hl-api-wallets.env.example
#   Master adres JSON yoksa: HL_MASTER_ADDRESS_<ALIAS> veya tek agentta HL_MASTER_ADDRESS
#
# İsteğe bağlı:
#   label            — görünen isim
#   hlWallet         — HL subaccount farklıysa; yoksa walletAddress kullanılır
#   forumApiKey      — dgc_... dashboard forum autopost
#   autoTrade        — true/false; signal webhook oto-trade (varsayılan: true)
#
# AGENTS_JSON=[{"alias":"raichu","apiKey":"acp-...","walletAddress":"0x...40hex...","hlApiWalletKey":"0x...64hex..."}]
AGENTS_JSON=

# AGENTS_JSON boşsa dosyadan okunur (Railway volume veya lokal; repoya secret koyma)
# AGENTS_JSON_PATH=./agents.local.json

# Port (Railway otomatik verir)
# PORT=3000

# ---------- Railway / Vercel HL v2 (özet) ----------
# AGENTS_JSON tek satır + her trade agent için:
#   HL_API_WALLET_KEY_<ALIAS>  (örn. HL_API_WALLET_KEY_FRIDAY)
# Ayrıntı: repoda DEPLOY_RAILWAY_VERCEL.md
