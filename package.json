{
  "name": "super-saiyan-raichu",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Super Saiyan Raichu — ACP v2 + Degen Claw (join_leaderboard, perp_deposit)",
  "scripts": {
    "acpv2": "node scripts/run-acp-v2.mjs",
    "acp:v2": "node scripts/run-acp-v2.mjs",
    "acp:configure": "node scripts/run-acp-v2.mjs configure",
    "whoami:v2": "node scripts/run-acp-v2.mjs agent whoami --json",
    "agent:list:v2": "node scripts/run-acp-v2.mjs --json agent list --page 1 --page-size 100",
    "dgclaw:join:acp": "node scripts/dgclaw-join-acp.mjs",
    "dgclaw:join": "node scripts/dgclaw-join-acp.mjs",
    "degen:dgclaw:join": "node scripts/dgclaw-join-acp.mjs",
    "dgclaw:fetch-key": "node scripts/dgclaw-fetch-dgclaw-key.mjs",
    "dgclaw:ensure-env": "node scripts/dgclaw-ensure-env.mjs",
    "dgclaw:env:taxerclaw": "node scripts/dgclaw-ensure-env.mjs --alias taxerclaw",
    "dgclaw:trade": "node scripts/run-dgclaw-tsx.mjs scripts/trade.ts",
    "dgclaw:activate-unified": "node scripts/run-dgclaw-tsx.mjs scripts/activate-unified.ts",
    "dgclaw:add-api-wallet": "node scripts/run-dgclaw-tsx.mjs scripts/add-api-wallet.ts",
    "legacy:list": "npx tsx scripts/dump-legacy-agents.ts",
    "legacy:list:v2": "node scripts/list-legacy-agents-acpv2.mjs",
    "degen:deposit": "node scripts/degen-perp-deposit-create.mjs",
    "degen:fund": "node scripts/degen-perp-deposit-fund.mjs",
    "degen:hl:deposit": "node scripts/degen-hl-deposit.mjs",
    "degen:hl:activate": "node scripts/run-dgclaw-tsx.mjs scripts/activate-unified.ts",
    "degen:hl:add-api-wallet": "node scripts/run-dgclaw-tsx.mjs scripts/add-api-wallet.ts",
    "ichimoku:migrate": "node scripts/print-ichimoku-migration.mjs",
    "ichimoku:forum-env": "node scripts/dgclaw-ensure-env.mjs --alias ichimoku",
    "ichimoku:prepare": "node scripts/dgclaw-ensure-env.mjs --alias ichimoku && node scripts/print-ichimoku-migration.mjs",
    "agents:set-lite-key": "node scripts/set-agents-local-lite-key.mjs",
    "hl:per-agent-env": "node scripts/hl-per-agent-env-split.mjs",
    "hl:add-api-wallet:all": "node scripts/hl-add-api-wallet-loop.mjs",
    "hl:add-api-wallet:all:dry": "node scripts/hl-add-api-wallet-loop.mjs --dry-run",
    "hl:add-api-wallet:alias": "node scripts/hl-add-api-wallet-for-alias.mjs",
    "hl:sync-api-keys": "node scripts/sync-hl-api-keys.mjs",
    "hl:bootstrap-secrets": "node scripts/sync-hl-api-keys.mjs --bootstrap",
    "hl:export-railway-vercel": "node scripts/export-hl-env-for-railway-vercel.mjs",
    "agents:json:merge": "node scripts/merge-agents-json-from-secrets.mjs --out=AGENTS_JSON.paste.txt --write-local",
    "acp:use-agent": "node scripts/acp-agent-use-by-alias.mjs"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.2",
    "axios": "^1.13.5",
    "dotenv": "^16.4.5",
    "telegraf": "^4.16.3",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
